# Bangko ng Seton - Environment Configuration Template
# Copy this file to .env and update values as needed

# ============================================
# Google Sheets Configuration (REQUIRED)
# ============================================
# Get this from your Google Sheet URL: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_SHEETS_ID=your_google_sheet_id_here

# ============================================
# Arduino Serial Connections
# ============================================
# For Windows: COM3, COM4, etc.
# For Linux: /dev/ttyUSB0, /dev/ttyACM0
# For Mac: /dev/tty.usbserial-xxx
SERIAL_PORT=COM3
ADMIN_PORT=COM3
BAUD_RATE=9600

# ============================================
# Transaction Settings
# ============================================
TRANSACTION_TIMEOUT=60
LOW_BALANCE_THRESHOLD=50.00
MAX_TRANSACTION_AMOUNT=500.00
MIN_BALANCE_ALLOWED=0.00

# ============================================
# System Behavior
# ============================================
DEBUG_MODE=false
OFFLINE_MODE=false
AUTO_ATTENDANCE=true

# ============================================
# Admin Dashboard (Flask App)
# ============================================
# REQUIRED: Must be changed before deployment. Server will refuse to start with this default value.
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=change-this-to-a-random-secure-key-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ============================================
# Finance Dashboard (Flask App)
# ============================================
FINANCE_USERNAME=finance
FINANCE_PASSWORD=changeme

# ============================================
# Cashier Dashboard (Flask App)
# ============================================
CASHIER_USERNAME=cashier
CASHIER_PASSWORD=changeme

# ============================================
# JWT Secret (Cashier Dashboard)
# ============================================
# REQUIRED: Must be changed before deployment. Server will refuse to start with the insecure default.
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-this-to-a-random-secure-jwt-secret

# ============================================
# API Server Settings
# ============================================
API_PORT=5001
API_DEBUG=False

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins (production domains only)
# MUST be set to your actual domain before deployment
# Do NOT leave as placeholder — leave blank to allow localhost only (dev)
# Example: CORS_ORIGINS=https://myapp.com,https://www.myapp.com
CORS_ORIGINS=YOUR_PRODUCTION_DOMAIN

# ============================================
# Production Settings (Uncomment for deployment)
# ============================================
# FLASK_ENV=production
# FLASK_DEBUG=0
