[Unit]
Description=BANKONGSETON Mobile/Web API (Flask gunicorn, /api/*)
After=network.target

[Service]
Type=notify
User=__USER__
Group=__USER__
WorkingDirectory=__APP_DIR__/backend/api
EnvironmentFile=__APP_DIR__/.env
ExecStart=__APP_DIR__/venv/bin/gunicorn -c __APP_DIR__/deploy/oracle/gunicorn_api.py api_server:app
Restart=on-failure
RestartSec=3
KillMode=mixed

[Install]
WantedBy=multi-user.target
