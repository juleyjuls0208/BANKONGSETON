[Unit]
Description=BANGONGSETON Tech/Admin Kiosk (Flask + SocketIO gunicorn, on-prem hardware)
After=network.target

[Service]
Type=notify
User=__USER__
Group=__USER__
WorkingDirectory=__APP_DIR__/backend/tech
EnvironmentFile=__APP_DIR__/.env
ExecStart=__APP_DIR__/venv/bin/gunicorn -c __APP_DIR__/deploy/oracle/gunicorn_tech.py tech_app:app
Restart=on-failure
RestartSec=3
KillMode=mixed

[Install]
WantedBy=multi-user.target
