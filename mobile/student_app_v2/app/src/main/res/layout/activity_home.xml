<?xml version="1.0" encoding="utf-8"?>
<!--
  Home screen — Material You / Apple Wallet-inspired
  • Full-bleed gradient balance card (hero)
  • Quick-action row (History, Pay, Settings) — pill chips
  • Budget tracker card
  • Lost-card banner (hidden by default)
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── Top chrome: app name + greeting ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="60dp"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good morning"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvStudentName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textColor="?attr/colorOnSurface" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/settingsButton"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:icon="@android:drawable/ic_menu_manage"
                        app:iconSize="22dp"
                        android:contentDescription="@string/settings_title" />

                </LinearLayout>

                <!-- ── Lost-card banner (hidden until active) ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/bannerLostCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorErrorContainer">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/home_banner_lost_card"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="?attr/colorOnErrorContainer" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ── Hero Balance Card ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/balanceCard"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="8dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorPrimary">

                    <!-- Decorative background circle (pseudo-depth) -->
                    <View
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_gravity="end|bottom"
                        android:layout_marginEnd="-60dp"
                        android:layout_marginBottom="-60dp"
                        android:background="@drawable/bg_circle_overlay"
                        android:alpha="0.15" />

                    <View
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_gravity="end|top"
                        android:layout_marginEnd="20dp"
                        android:layout_marginTop="-40dp"
                        android:background="@drawable/bg_circle_overlay"
                        android:alpha="0.1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="28dp"
                        android:gravity="bottom">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/balance_label"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="#FFFFFFB0"
                            android:letterSpacing="0.06" />

                        <!-- Balance amount + loading state -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp">

                            <TextView
                                android:id="@+id/balanceText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₱0.00"
                                android:textSize="44sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:letterSpacing="-0.02"
                                android:visibility="invisible" />

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/balanceProgressBar"
                                android:layout_width="160dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginTop="16dp"
                                android:indeterminate="true"
                                app:indicatorColor="#FFFFFF"
                                app:trackColor="#FFFFFF40"
                                app:trackCornerRadius="4dp" />

                        </FrameLayout>

                        <!-- Card number hint -->
                        <TextView
                            android:id="@+id/tvCardHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="—"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="#FFFFFF80"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ── Quick Actions row ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="4dp"
                    android:gravity="center">

                    <!-- History -->
                    <LinearLayout
                        android:id="@+id/transactionsButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorPrimaryContainer">

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_recent_history"
                                android:tint="?attr/colorOnPrimaryContainer"
                                android:contentDescription="@string/action_history" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/action_history"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="?attr/colorOnSurface" />

                    </LinearLayout>

                    <!-- QR Pay (centre, larger) -->
                    <LinearLayout
                        android:id="@+id/qrPayButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorSecondaryContainer">

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_camera"
                                android:tint="?attr/colorOnSecondaryContainer"
                                android:contentDescription="@string/action_qr_pay" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/action_qr_pay"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="?attr/colorOnSurface" />

                    </LinearLayout>

                    <!-- Settings -->
                    <LinearLayout
                        android:id="@+id/settingsButtonAlt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp"
                        android:visibility="gone">

                        <!-- Placeholder; settings accessible from top icon -->

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Section: This Month / Budget ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/budget_monthly"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/budgetCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_container">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/budgetProgress"
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                app:indicatorSize="64dp"
                                app:trackThickness="7dp"
                                android:indeterminate="false"
                                app:trackColor="?attr/colorSurfaceVariant"
                                app:indicatorColor="?attr/colorPrimary" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="16dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvBudgetPercent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textAppearance="?attr/textAppearanceHeadlineMedium"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:id="@+id/tvBudgetSpend"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/budget_no_limit"
                                    android:textAppearance="?attr/textAppearanceBodyMedium"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSetBudget"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/budget_set_limit"
                                android:textAllCaps="false"
                                app:cornerRadius="12dp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ── Recent Transactions header ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="4dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSeeAllTransactions"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textAllCaps="false" />

                </LinearLayout>

                <!-- Recent transactions placeholder (populated by HomeActivity) -->
                <LinearLayout
                    android:id="@+id/recentTransactionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="32dp" />

                <!-- Empty state for recent transactions -->
                <LinearLayout
                    android:id="@+id/emptyRecentState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No transactions yet"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

                <!-- Generic loading indicator -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="24dp"
                    android:visibility="gone" />

            </LinearLayout>

        </ScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
