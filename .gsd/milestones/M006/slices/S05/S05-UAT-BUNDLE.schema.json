{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bankongseton.local/gsd/m006/s05/uat-bundle.schema.json",
  "title": "M006 S05 Physical UAT Evidence Bundle",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "base_url",
    "overall",
    "required_flows",
    "physical_checks",
    "request_trace",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "base_url": { "type": "string", "minLength": 1 },
    "overall": {
      "type": "object",
      "required": [
        "live_ready",
        "exit_code",
        "required_flow_count",
        "required_live_success_count",
        "live_success_count",
        "offline_fallback_count",
        "failed_count",
        "failure_reasons",
        "schema_valid",
        "schema_errors"
      ],
      "properties": {
        "live_ready": { "type": "boolean" },
        "exit_code": { "type": "integer", "enum": [0, 1] },
        "required_flow_count": { "type": "integer", "minimum": 0 },
        "required_live_success_count": { "type": "integer", "minimum": 0 },
        "live_success_count": { "type": "integer", "minimum": 0 },
        "offline_fallback_count": { "type": "integer", "minimum": 0 },
        "failed_count": { "type": "integer", "minimum": 0 },
        "failure_reasons": { "type": "array", "items": { "type": "string" } },
        "schema_valid": { "type": "boolean" },
        "schema_errors": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "required_flows": {
      "type": "object",
      "required": [
        "products_live_data",
        "arduino_heartbeat",
        "card_read_sale_completion",
        "student_qr_confirm",
        "nfc_compatible_completion"
      ],
      "additionalProperties": {
        "type": "object",
        "required": [
          "flow",
          "classification",
          "endpoint",
          "resolved_endpoint",
          "status_code",
          "source",
          "artifact_refs",
          "failure_reasons"
        ],
        "properties": {
          "flow": { "type": "string", "minLength": 1 },
          "classification": {
            "type": "string",
            "enum": ["live_success", "offline_fallback", "failed"]
          },
          "endpoint": { "type": "string", "minLength": 1 },
          "resolved_endpoint": { "type": "string" },
          "status_code": { "type": "integer", "minimum": 0 },
          "source": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "artifact_refs": { "type": "array", "items": { "type": "string" } },
          "failure_reasons": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "physical_checks": {
      "type": "object",
      "required": [
        "arduino_heartbeat",
        "card_read_sale_completion",
        "student_qr_confirm",
        "nfc_compatible_completion"
      ],
      "additionalProperties": {
        "type": "object",
        "required": [
          "classification",
          "observed_at",
          "artifact_refs",
          "artifact_count",
          "missing_artifacts",
          "failure_reasons"
        ],
        "properties": {
          "classification": {
            "type": "string",
            "enum": ["live_success", "offline_fallback", "failed"]
          },
          "observed_at": { "type": ["string", "null"] },
          "artifact_refs": { "type": "array", "items": { "type": "string" } },
          "artifact_count": { "type": "integer", "minimum": 0 },
          "missing_artifacts": { "type": "array", "items": { "type": "string" } },
          "failure_reasons": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "request_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "phase",
          "method",
          "url",
          "endpoint",
          "resolved_endpoint",
          "status_code",
          "classification",
          "timestamp"
        ],
        "properties": {
          "phase": { "type": "string", "minLength": 1 },
          "method": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1 },
          "endpoint": { "type": "string", "minLength": 1 },
          "resolved_endpoint": { "type": "string", "minLength": 1 },
          "status_code": { "type": "integer", "minimum": 0 },
          "classification": {
            "type": "string",
            "enum": ["live_success", "offline_fallback", "failed"]
          },
          "timestamp": { "type": "string", "minLength": 1 },
          "notes": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["items", "counts", "missing_references"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["artifact_id", "type", "path", "captured_at"],
            "properties": {
              "artifact_id": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "captured_at": { "type": "string", "minLength": 1 },
              "notes": { "type": ["string", "null"] }
            },
            "additionalProperties": true
          }
        },
        "counts": {
          "type": "object",
          "required": ["total"],
          "properties": {
            "total": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "missing_references": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["check", "artifact_id"],
            "properties": {
              "check": { "type": "string", "minLength": 1 },
              "artifact_id": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
